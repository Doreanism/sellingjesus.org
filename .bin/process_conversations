#!/bin/bash
# Process conversations data
set -e
ROOT="$(realpath "$(dirname "${BASH_SOURCE[0]}")/..")"
SCRIPT="$ROOT/.bin/process_conversations.mjs"

cd "$ROOT/src/learn"
node "$SCRIPT" conversations
node "$SCRIPT" corinthians

for dir in "$ROOT"/src/i18n/*/learn; do
    [ -d "$dir" ] || continue
    cd "$dir"
    node "$SCRIPT" conversations
    node "$SCRIPT" corinthians
done
